        "@types/stylis": "^4.2.6",
        "@vitejs/plugin-react": "^4.3.4",
        "onchange": "^7.1.0",
        "prettier": "^3.5.3",
        "run-script-os": "^1.1.6",
        "typescript": "^5.8.3",
        "vite": "^6.2.6",
        "vite-tsconfig-paths": "^5.1.4"
    }
}
